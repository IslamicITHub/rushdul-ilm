# ============================================================
# Rushd-ul-Ilm Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit the actual .env file to git!
# ============================================================

# ── NVIDIA NIM API Key ──────────────────────────────────────
# Used for the primary LLM (meta/llama-3.3-70b-instruct)
# Get your free key from: https://build.nvidia.com/
# If not set, the system falls back to local Ollama (Qwen3:4b)
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# ── Hugging Face Token ──────────────────────────────────────
# Used for downloading gated models (IndicTrans2, Indic Parler TTS)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

